<view class="address-container">
  <!-- 地址列表 -->
  <view class="address-list">
    <view class="address-card {{isSelectMode ? 'selectable' : ''}}" wx:for="{{addresses}}" wx:key="id" bindtap="onAddressTap" data-id="{{item.id}}">
      <view class="address-header">
        <view class="address-tags">
          <view class="tag default" wx:if="{{item.isDefault}}">默认</view>
          <view class="tag">{{item.tag}}</view>
        </view>
        <view class="address-actions" wx:if="{{!isSelectMode}}">
          <text class="action-btn" catchtap="editAddress" data-id="{{item.id}}">编辑</text>
          <text class="action-btn delete" catchtap="deleteAddress" data-id="{{item.id}}">删除</text>
        </view>
        <view class="select-indicator" wx:if="{{isSelectMode}}">
          <text class="select-text">选择</text>
          <text class="select-arrow">›</text>
        </view>
      </view>

      <view class="address-content">
        <view class="address-name-phone">
          <text class="address-name">{{item.name}}</text>
          <text class="address-phone">{{item.phone}}</text>
        </view>
        <text class="address-detail">{{item.province}}{{item.city}}{{item.district}}{{item.detail}}</text>
      </view>

      <view class="address-footer" wx:if="{{!isSelectMode}}">
        <checkbox class="default-checkbox" checked="{{item.isDefault}}" bindtap="setDefault" data-id="{{item.id}}" />
        <text class="default-text">设为默认地址</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-address" wx:if="{{addresses.length === 0}}">
    <text class="empty-icon">📍</text>
    <text class="empty-text">暂无收货地址</text>
  </view>

  <!-- 添加按钮 -->
  <view class="add-btn" bindtap="addAddress">
    <text class="add-icon">+</text>
    <text class="add-text">添加新地址</text>
  </view>
</view>
