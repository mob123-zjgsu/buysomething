.signin-container { background: #f5f5f5; min-height: 100vh; }
.signin-header { background: linear-gradient(135deg, #FF6B6B, #e74c3c); padding: 60rpx 40rpx; text-align: center; }
.signin-title { font-size: 44rpx; color: #fff; font-weight: bold; display: block; }
.signin-subtitle { font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 10rpx; display: block; }
.signin-card { background: #fff; margin: -40rpx 30rpx 20rpx; border-radius: 16rpx; padding: 40rpx; text-align: center; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08); }
.signin-count { font-size: 28rpx; color: #666; display: block; margin-bottom: 24rpx; }
.signin-btn { background: linear-gradient(135deg, #FF6B6B, #e74c3c); color: #fff; border: none; border-radius: 40rpx; font-size: 32rpx; padding: 20rpx 60rpx; }
.signin-btn.signed { background: #ccc; }
.signin-reward { font-size: 28rpx; color: #e74c3c; font-weight: bold; margin-top: 20rpx; display: block; }
.reward-rules { background: #fff; margin: 0 30rpx 20rpx; border-radius: 16rpx; padding: 30rpx; }
.rules-title { font-size: 28rpx; font-weight: bold; color: #333; display: block; margin-bottom: 16rpx; }
.rule-row { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid #f0f0f0; font-size: 26rpx; color: #666; }
.rule-row.highlight { color: #e74c3c; font-weight: bold; }
.history { background: #fff; margin: 0 30rpx; border-radius: 16rpx; padding: 30rpx; }
.history-title { font-size: 28rpx; font-weight: bold; color: #333; display: block; margin-bottom: 16rpx; }
.history-item { display: flex; justify-content: space-between; padding: 10rpx 0; font-size: 24rpx; color: #666; }
.history-reward { color: #e74c3c; }
.empty { text-align: center; color: #999; padding: 30rpx 0; font-size: 24rpx; }
