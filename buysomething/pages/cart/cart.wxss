.cart-container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 140rpx;
}

/* 空状态 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 48rpx;
}

.btn-go-shopping {
  width: 320rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

/* 购物车内容 */
.cart-content {
  padding-top: 20rpx;
}

/* 顶部导航 */
.cart-navbar {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background-color: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.nav-action {
  font-size: 28rpx;
  color: #666666;
}

/* 店铺区块 */
.shop-section {
  margin-bottom: 16rpx;
  background-color: #FFFFFF;
  padding: 0 24rpx;
}

.shop-header {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.shop-checkbox {
  margin-right: 16rpx;
}

.shop-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

/* 购物车商品项 */
.cart-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.cart-item:last-child {
  border-bottom: none;
}

.item-checkbox {
  margin-right: 16rpx;
  margin-top: 80rpx;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.product-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-spec {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 24rpx;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.product-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF6B6B;
}

/* 数量控制 */
.quantity-control {
  display: flex;
  align-items: center;
}

.quantity-btn {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  background-color: #F5F5F5;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333333;
  padding: 0;
}

.quantity-num {
  width: 64rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333333;
}

/* 底部结算栏 */
.checkout-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  box-sizing: border-box;
  background-color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.08);
  z-index: 99;
}

.select-all {
  display: flex;
  align-items: center;
}

.select-all-checkbox {
  margin-right: 16rpx;
}

.select-all-text {
  font-size: 28rpx;
  color: #666666;
}

.checkout-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.total-price {
  display: flex;
  align-items: baseline;
}

.price-label {
  font-size: 28rpx;
  color: #666666;
}

.price-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF6B6B;
  margin-left: 8rpx;
}

.price-note {
  font-size: 24rpx;
  color: #999999;
  margin-left: 8rpx;
}

.selected-count {
  font-size: 28rpx;
  color: #666666;
}

.btn-checkout {
  width: 180rpx;
  height: 64rpx;
  line-height: 64rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #FFFFFF;
  border-radius: 32rpx;
  font-size: 28rpx;
  border: none;
  padding: 0;
}

.btn-checkout[disabled] {
  background: #CCCCCC;
}
