/* 全屏加载 */
.loading-wrapper.fullscreen {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

/* 行内加载 */
.loading-wrapper.inline {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 旋转动画 */
.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  position: relative;
}

.spinner-item {
  position: absolute;
  width: 100%;
  height: 100%;
  animation: spinner 1.2s linear infinite;
}

.spinner-item::before {
  content: '';
  display: block;
  width: 12rpx;
  height: 12rpx;
  background-color: #FF6B6B;
  border-radius: 50%;
  margin: 0 auto;
}

.spinner-item:nth-child(1) { animation-delay: -1.1s; transform: rotate(0deg); }
.spinner-item:nth-child(2) { animation-delay: -1.0s; transform: rotate(60deg); }
.spinner-item:nth-child(3) { animation-delay: -0.9s; transform: rotate(120deg); }
.spinner-item:nth-child(4) { animation-delay: -0.8s; transform: rotate(180deg); }
.spinner-item:nth-child(5) { animation-delay: -0.7s; transform: rotate(240deg); }
.spinner-item:nth-child(6) { animation-delay: -0.6s; transform: rotate(300deg); }

@keyframes spinner {
  0% { opacity: 1; }
  100% { opacity: 0.3; }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #666666;
}
