.register-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
  position: relative;
}

.back-btn {
  position: absolute;
  top: 40rpx;
  left: 20rpx;
  font-size: 60rpx;
  color: #fff;
  z-index: 10;
  padding: 10rpx 20rpx;
}

.logo-section {
  text-align: center;
  padding: 120rpx 0 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
}

.welcome-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.welcome-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.register-form {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

.test-tip {
  background: #fff7e6;
  border: 1rpx solid #ffd591;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.test-tip text {
  font-size: 24rpx;
  color: #fa8c16;
  line-height: 1.5;
}

.input-group {
  margin-bottom: 30rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 88rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.input-wrapper:focus-within {
  border-color: #667eea;
  background: #fff;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
  height: 100%;
  color: #333;
}

.code-input {
  flex: 1;
  margin-right: 20rpx;
}

.eye-icon {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.btn-code {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  height: 60rpx;
  line-height: 44rpx;
  background: #667eea;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  white-space: nowrap;
}

.btn-code.countdown {
  background: #ccc;
  color: #666;
}

.password-strength {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 0 4rpx;
}

.strength-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 16rpx;
}

.strength-bars {
  display: flex;
  gap: 8rpx;
}

.strength-bar {
  width: 60rpx;
  height: 8rpx;
  background: #eee;
  border-radius: 4rpx;
  transition: all 0.3s;
}

.strength-bar.active {
  background: #999;
}

.strength-bar.weak {
  background: #ff4d4f;
}

.strength-bar.medium {
  background: #faad14;
}

.strength-bar.strong {
  background: #52c41a;
}

.strength-text {
  margin-left: 16rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.strength-text.weak {
  color: #ff4d4f;
}

.strength-text.medium {
  color: #faad14;
}

.strength-text.strong {
  color: #52c41a;
}

.btn-register {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.btn-register.disabled {
  background: #ccc;
  opacity: 0.6;
}

.login-section {
  text-align: center;
  margin-top: 40rpx;
}

.login-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.login-link {
  font-size: 28rpx;
  color: #667eea;
  font-weight: bold;
  margin-left: 8rpx;
}

.agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
  flex-wrap: wrap;
}

.agreement-checkbox {
  margin-right: 8rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.agreement-link {
  font-size: 24rpx;
  color: #fff;
  text-decoration: underline;
  margin: 0 4rpx;
}
