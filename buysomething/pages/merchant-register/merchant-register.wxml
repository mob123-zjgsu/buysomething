<!-- 商家注册页面 -->
<view class="merchant-register">
  <!-- 返回按钮 -->
  <view class="back-btn" bindtap="goBack">
    <text>‹</text>
  </view>

  <!-- 标题 -->
  <view class="header-section">
    <text class="header-icon">🏪</text>
    <text class="header-title">商家注册</text>
    <text class="header-subtitle">创建您的商家账号</text>
  </view>

  <!-- 注册表单 -->
  <view class="register-form">
    <view class="input-group">
      <text class="input-label">商家名称 *</text>
      <view class="input-wrapper">
        <input class="input-field" placeholder="请输入商家名称" bindinput="onMerchantNameInput" value="{{merchantName}}" />
      </view>
    </view>

    <view class="input-group">
      <text class="input-label">主营产品 *</text>
      <view class="input-wrapper">
        <input class="input-field" placeholder="如：服装、电子产品" bindinput="onMainProductsInput" value="{{mainProducts}}" />
      </view>
    </view>

    <view class="input-group">
      <text class="input-label">联系人</text>
      <view class="input-wrapper">
        <input class="input-field" placeholder="请输入联系人姓名（选填）" bindinput="onContactPersonInput" value="{{contactPerson}}" />
      </view>
    </view>

    <view class="input-group">
      <text class="input-label">手机号 *</text>
      <view class="input-wrapper">
        <text class="input-icon">📱</text>
        <input class="input-field" type="number" placeholder="请输入手机号" maxlength="11" bindinput="onPhoneInput" value="{{phone}}" />
      </view>
    </view>

    <view class="input-group">
      <text class="input-label">密码 *</text>
      <view class="input-wrapper">
        <text class="input-icon">🔒</text>
        <input class="input-field" type="{{showPassword ? 'text' : 'password'}}" placeholder="请设置登录密码（至少6位）" bindinput="onPasswordInput" value="{{password}}" />
        <text class="eye-icon" bindtap="togglePassword">
          {{showPassword ? '👁️' : '👁️‍🗨️'}}
        </text>
      </view>
    </view>

    <view class="input-group">
      <text class="input-label">确认密码 *</text>
      <view class="input-wrapper">
        <text class="input-icon">🔒</text>
        <input class="input-field" type="password" placeholder="请再次输入密码" bindinput="onConfirmPasswordInput" value="{{confirmPassword}}" />
      </view>
    </view>

    <button class="btn-register {{!canRegister ? 'disabled' : ''}}" disabled="{{!canRegister}}" bindtap="doRegister">
      提交注册
    </button>

    <view class="tips">
      <text class="tip-text">📌 注册后需要管理员审核，审核通过后方可登录</text>
    </view>
  </view>
</view>