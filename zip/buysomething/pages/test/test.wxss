.container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.refresh-btn {
  background-color: #FFFFFF;
  color: #FF6B6B;
  font-size: 26rpx;
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  border: none;
}

.refresh-btn::after {
  border: none;
}

/* 状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #FFFFFF;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.status-text {
  font-size: 28rpx;
  color: #333333;
}

.status-count {
  font-size: 26rpx;
  color: #666666;
}

/* 日志区域 */
.log-section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

.log-container {
  background-color: #1e1e1e;
  border-radius: 12rpx;
  padding: 20rpx;
  height: 400rpx;
}

.log-item {
  color: #4ec9b0;
  font-size: 24rpx;
  font-family: 'Courier New', monospace;
  line-height: 1.8;
  word-break: break-all;
  margin-bottom: 8rpx;
}

.log-item.error {
  color: #f48771;
}

.log-item.success {
  color: #6a9955;
}

.log-item.info {
  color: #dcdcaa;
}

.log-empty {
  color: #666666;
  font-size: 26rpx;
  text-align: center;
  padding: 100rpx 0;
}

/* 结果区域 */
.result-section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
}

.result-empty {
  color: #999999;
  font-size: 28rpx;
  text-align: center;
  padding: 60rpx 0;
}

.result-item {
  background-color: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.result-item:last-child {
  margin-bottom: 0;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.result-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.result-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.result-status.success {
  background-color: #E8F8E8;
  color: #52C41A;
}

.result-status.error {
  background-color: #FFF0F0;
  color: #FF6B6B;
}

.result-message {
  font-size: 24rpx;
  color: #666666;
  word-break: break-all;
  display: block;
}
