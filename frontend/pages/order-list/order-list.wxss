.order-list-container {
  min-height: 100vh;
  background-color: #F5F5F5;
}

/* 订单标签 */
.order-tabs {
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.tabs-scroll {
  white-space: nowrap;
  display: flex;
}

.tab-item {
  padding: 24rpx 40rpx;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #FF6B6B;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #FF6B6B;
  border-radius: 2rpx;
}

/* 订单列表 */
.order-list {
  padding: 16rpx 24rpx;
}

.order-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.order-shop {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.order-status {
  font-size: 28rpx;
  color: #999999;
}

.order-status.pending {
  color: #FF6B6B;
}

.order-status.shipped {
  color: #4ECDC4;
}

.order-status.received {
  color: #FFB347;
}

.order-status.commented {
  color: #A855F7;
}

/* 订单商品 */
.order-products {
  padding: 20rpx 0;
}

.product-item {
  display: flex;
  margin-bottom: 20rpx;
}

.product-item:last-child {
  margin-bottom: 0;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.product-name {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-spec {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.product-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.product-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF6B6B;
}

.product-quantity {
  font-size: 24rpx;
  color: #999999;
}

/* 订单底部 */
.order-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid #F5F5F5;
}

.order-total {
  font-size: 28rpx;
  color: #666666;
}

.total-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF6B6B;
}

.order-actions {
  display: flex;
  gap: 16rpx;
}

.btn-action {
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  border: none;
}

.btn-secondary {
  background-color: #F5F5F5;
  color: #666666;
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #FFFFFF;
}

/* 空状态 */
.empty-orders {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}
