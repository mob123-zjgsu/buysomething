.review-list-container { min-height: 100vh; background: #f5f5f5; padding: 20rpx; }
.empty { text-align: center; padding: 150rpx 0; }
.empty-icon { font-size: 80rpx; display: block; }
.empty-text { font-size: 28rpx; color: #999; }

.review-item { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.review-header { display: flex; align-items: center; margin-bottom: 12rpx; }
.reviewer-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; font-size: 22rpx; display: flex; align-items: center; justify-content: center; margin-right: 16rpx; flex-shrink: 0; }
.reviewer-info { flex: 1; }
.reviewer-name { font-size: 28rpx; color: #333; display: block; }
.review-stars { display: flex; gap: 4rpx; }
.star-icon { font-size: 24rpx; }
.review-time { font-size: 22rpx; color: #999; }
.review-body { font-size: 28rpx; color: #555; line-height: 1.6; padding-left: 80rpx; }
