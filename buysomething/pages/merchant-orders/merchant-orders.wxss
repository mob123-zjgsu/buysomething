.container { background: #f5f5f5; min-height: 100vh; }
.tabs { display: flex; background: #fff; }
.tab { flex: 1; text-align: center; padding: 24rpx; font-size: 28rpx; color: #666; border-bottom: 4rpx solid transparent; }
.tab.active { color: #e74c3c; border-color: #e74c3c; }
.empty { text-align: center; padding: 150rpx 0; }
.empty-icon { font-size: 80rpx; display: block; }
.empty-text { font-size: 28rpx; color: #999; }
.order-list { padding: 20rpx; }
.order-card { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 16rpx; }
.order-header { display: flex; justify-content: space-between; margin-bottom: 12rpx; }
.order-no { font-size: 24rpx; color: #666; }
.order-status { font-size: 24rpx; color: #e74c3c; }
.order-body { display: flex; justify-content: space-between; padding: 16rpx 0; }
.order-count { font-size: 26rpx; color: #333; }
.order-price { font-size: 28rpx; color: #e74c3c; font-weight: bold; }
.order-footer { display: flex; justify-content: space-between; align-items: center; }
.order-time { font-size: 22rpx; color: #999; }
.ship-btn { background: #e74c3c; color: #fff; font-size: 24rpx; border-radius: 24rpx; padding: 10rpx 30rpx; border: none; }
