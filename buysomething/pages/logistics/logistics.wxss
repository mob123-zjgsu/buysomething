.logistics-container {
  background: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.logistics-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.logistics-title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}

.logistics-company {
  margin-top: 12rpx;
}

.company-name {
  font-size: 28rpx;
  opacity: 0.9;
}

.tracking-no {
  font-size: 24rpx;
  opacity: 0.7;
  margin-left: 20rpx;
}

/* 地图 */
.map-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.logistics-map {
  border-radius: 12rpx;
  width: 100%;
}

.progress-bar {
  height: 28rpx;
  background: #e8eaf6;
  border-radius: 14rpx;
  overflow: hidden;
  position: relative;
  margin-top: 20rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 14rpx;
  transition: width 0.8s ease;
}

.progress-text {
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 20rpx;
  color: #333;
  font-weight: bold;
}

/* 时间快进 */
.time-control-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.time-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.time-buttons {
  display: flex;
  gap: 16rpx;
}

.btn-time {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 0;
}

.btn-time[disabled] {
  background: #ccc;
  color: #fff;
}

.btn-time-fast {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.time-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
  display: block;
  text-align: right;
}

/* 操作按钮区 */
.action-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 24rpx;
  margin-bottom: 20rpx;
}

.status-info {
  margin-bottom: 24rpx;
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.status-label {
  font-size: 26rpx;
  color: #999;
}

.status-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.status-done {
  color: #4CAF50;
}

.action-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.btn-action {
  min-width: calc(50% - 16rpx);
  height: 80rpx;
  line-height: 80rpx;
  font-size: 26rpx;
  border: none;
  border-radius: 12rpx;
  padding: 0 20rpx;
  flex-grow: 1;
}

.btn-primary-action {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  min-width: 100%;
  font-weight: bold;
}

.btn-urge {
  background: #fff3e0;
  color: #e65100;
  border: 2rpx solid #ffcc80;
}

.btn-refresh {
  background: #e8f5e9;
  color: #2e7d32;
  border: 2rpx solid #a5d6a7;
}

.btn-aftersale {
  background: #e3f2fd;
  color: #1565c0;
  border: 2rpx solid #90caf9;
}

.btn-complain {
  background: #ffebee;
  color: #c62828;
  border: 2rpx solid #ef9a9a;
}

/* 时间线 */
.events-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.events-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  display: block;
}

.timeline {
  position: relative;
  padding-left: 30rpx;
}

.timeline-item {
  display: flex;
  padding-bottom: 24rpx;
  position: relative;
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: 6rpx;
  top: 20rpx;
  bottom: 0;
  width: 2rpx;
  background: #e0e0e0;
}

.timeline-item:last-child::before {
  display: none;
}

.timeline-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #e0e0e0;
  margin-right: 16rpx;
  margin-top: 6rpx;
  flex-shrink: 0;
}

.timeline-dot.active {
  background: #667eea;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.2);
}

.timeline-dot.dot-complaint {
  background: #c62828;
}

.timeline-dot.dot-urge {
  background: #ff9800;
}

.timeline-dot.dot-aftersale {
  background: #1565c0;
}

.timeline-content {
  flex: 1;
}

.timeline-desc {
  font-size: 26rpx;
  color: #333;
  display: block;
}

.timeline-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.empty-events {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  padding: 30rpx 0;
}
