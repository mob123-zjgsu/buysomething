.container { background: #f5f5f5; min-height: 100vh; }
.empty { text-align: center; padding: 150rpx 0; }
.empty-icon { font-size: 80rpx; display: block; }
.empty-text { font-size: 28rpx; color: #999; }
.product-list { padding: 20rpx; padding-bottom: 120rpx; }
.product-card { background: #fff; border-radius: 12rpx; padding: 20rpx; margin-bottom: 16rpx; display: flex; }
.product-img { width: 120rpx; height: 120rpx; border-radius: 8rpx; flex-shrink: 0; }
.product-info { flex: 1; margin-left: 20rpx; }
.product-name { font-size: 28rpx; color: #333; display: block; }
.product-price { font-size: 30rpx; color: #e74c3c; font-weight: bold; display: block; margin-top: 8rpx; }
.product-status { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 16rpx; display: inline-block; margin-top: 8rpx; }
.product-status.online { background: #e8f5e9; color: #4CAF50; }
.product-status.pending { background: #fff3e0; color: #FF9800; }
.product-status.offline { background: #ffebee; color: #e74c3c; }
.product-actions { display: flex; flex-direction: column; gap: 12rpx; justify-content: center; }
.action-btn { font-size: 22rpx; padding: 8rpx 16rpx; border-radius: 20rpx; }
.action-btn.edit { color: #2196F3; background: #e3f2fd; }
.action-btn.delete { color: #e74c3c; background: #ffebee; }
.add-fab { position: fixed; right: 40rpx; bottom: 100rpx; width: 100rpx; height: 100rpx; background: #e74c3c; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 6rpx 20rpx rgba(231, 76, 60, 0.3); }
.fab-icon { font-size: 48rpx; color: #fff; line-height: 1; }
