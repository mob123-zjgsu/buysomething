.messages-container { background: #f5f5f5; min-height: 100vh; }
.header-bar { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 30rpx; background: #fff; border-bottom: 1rpx solid #eee; }
.title { font-size: 28rpx; color: #333; font-weight: bold; }
.read-all { font-size: 24rpx; color: #e74c3c; }
.empty { text-align: center; padding: 150rpx 0; }
.empty-icon { font-size: 80rpx; display: block; }
.empty-text { font-size: 28rpx; color: #999; }
.msg-list { padding: 20rpx; }
.msg-item { display: flex; background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 16rpx; position: relative; }
.msg-item.unread { border-left: 6rpx solid #e74c3c; }
.msg-icon { font-size: 40rpx; margin-right: 20rpx; }
.msg-content { flex: 1; }
.msg-title { font-size: 28rpx; color: #333; font-weight: bold; display: block; }
.msg-desc { font-size: 24rpx; color: #666; display: block; margin-top: 8rpx; }
.msg-time { font-size: 22rpx; color: #999; margin-top: 8rpx; display: block; }
.unread-dot { width: 14rpx; height: 14rpx; border-radius: 50%; background: #e74c3c; position: absolute; right: 24rpx; top: 50%; transform: translateY(-50%); }
