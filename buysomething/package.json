{
  "name": "buysomething",
  "version": "1.0.0",
  "description": "优选购物小程序",
  "scripts": {
    "test": "jest tests/ --passWithNoTests",
    "test:coverage": "jest tests/ --coverage",
    "lint": "eslint cloudfunctions/**/*.js pages/**/*.js",
    "lint:fix": "eslint cloudfunctions/**/*.js pages/**/*.js --fix"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "pptxgenjs": "^4.0.1"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "cloudfunctions/**/*.js",
      "pages/**/*.js",
      "tests/**/*.js"
    ],
    "coverageReporters": [
      "text",
      "lcov"
    ],
    "coverageDirectory": "coverage",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
