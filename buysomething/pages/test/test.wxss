.container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding: 20rpx;
  padding-bottom: 120rpx;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  display: block;
  margin-top: 8rpx;
}

/* 测试类别选择 */
.category-bar {
  background-color: #FFFFFF;
  padding: 20rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.category-tabs {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 24rpx;
  color: #666666;
  border-bottom: 4rpx solid transparent;
}

.tab.active {
  color: #667eea;
  border-bottom-color: #667eea;
  font-weight: bold;
}

.start-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 20rpx;
  border-radius: 40rpx;
  border: none;
}

.start-btn.disabled {
  background: #CCCCCC;
}

.start-btn::after {
  border: none;
}

/* 统计信息 */
.stats-bar {
  display: flex;
  justify-content: space-around;
  background-color: #FFFFFF;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  display: block;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
  display: block;
  margin-top: 4rpx;
}

.stat-item.success .stat-value {
  color: #52C41A;
}

.stat-item.error .stat-value {
  color: #FF6B6B;
}

/* 进度条 */
.progress-bar {
  background-color: #FFF9E6;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.progress-text {
  font-size: 24rpx;
  color: #FF9800;
}

/* 结果区域 */
.result-section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.section-count {
  font-size: 24rpx;
  color: #999999;
}

.result-empty {
  color: #CCCCCC;
  font-size: 28rpx;
  text-align: center;
  padding: 60rpx 0;
}

.result-item {
  background-color: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border-left: 4rpx solid #52C41A;
}

.result-item.error {
  border-left-color: #FF6B6B;
}

.result-item:last-child {
  margin-bottom: 0;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.result-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333333;
}

.result-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.result-status.success {
  background-color: #E8F8E8;
  color: #52C41A;
}

.result-status.error {
  background-color: #FFF0F0;
  color: #FF6B6B;
}

.result-message {
  font-size: 24rpx;
  color: #666666;
  display: block;
}

.result-time {
  font-size: 20rpx;
  color: #999999;
  display: block;
  margin-top: 4rpx;
}

/* 日志区域 */
.log-section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.log-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.clear-btn {
  font-size: 22rpx;
  color: #999999;
  padding: 8rpx 16rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
}

.clear-btn::after {
  border: none;
}

.log-container {
  background-color: #1e1e1e;
  border-radius: 12rpx;
  padding: 16rpx;
  height: 350rpx;
}

.log-item {
  color: #4ec9b0;
  font-size: 22rpx;
  font-family: 'Courier New', monospace;
  line-height: 1.6;
  word-break: break-all;
  margin-bottom: 6rpx;
}

.log-item.error {
  color: #f48771;
}

.log-item.success {
  color: #6a9955;
}

.log-item.info {
  color: #dcdcaa;
}

.log-empty {
  color: #666666;
  font-size: 24rpx;
  text-align: center;
  padding: 80rpx 0;
}

/* 导出按钮 */
.export-btn {
  background: linear-gradient(135deg, #52C41A 0%, #389E0D 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 24rpx;
  border-radius: 40rpx;
  margin-top: 20rpx;
}

.export-btn::after {
  border: none;
}
