<view class="search-container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索商品" value="{{keyword}}" bindinput="onInput" bindconfirm="onSearch" focus />
    <text class="search-btn" bindtap="onSearch">搜索</text>
    <text class="clear-btn" bindtap="onClear" wx:if="{{keyword}}">✕</text>
  </view>

  <!-- 搜索结果 -->
  <view class="results" wx:if="{{searched}}">
    <view class="empty-result" wx:if="{{results.length === 0}}">
      <text>未找到相关商品</text>
    </view>
    <view class="result-item" wx:for="{{results}}" wx:key="_id" bindtap="goToProduct" data-id="{{item._id}}">
      <image class="result-img" src="{{item.image || '/images/product1.jpg'}}" mode="aspectFill" />
      <view class="result-info">
        <text class="result-name">{{item.name}}</text>
        <text class="result-price">¥{{item.price}}</text>
      </view>
    </view>
  </view>

  <!-- 搜索历史 -->
  <view class="history" wx:if="{{!searched && history.length > 0}}">
    <view class="history-header">
      <text class="history-title">搜索历史</text>
      <text class="clear-history" bindtap="clearHistory">清除</text>
    </view>
    <view class="history-list">
      <view class="history-item" wx:for="{{history}}" wx:key="*this" bindtap="tapHistory" data-kw="{{item}}">{{item}}</view>
    </view>
  </view>
</view>
