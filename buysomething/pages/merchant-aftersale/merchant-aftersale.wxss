.container { min-height: 100vh; background: #f5f5f5; }
.tabs { display: flex; background: #fff; }
.tab { flex: 1; text-align: center; padding: 24rpx; font-size: 28rpx; color: #666; border-bottom: 4rpx solid transparent; }
.tab.active { color: #667eea; border-color: #667eea; }
.empty { text-align: center; padding: 150rpx 0; }
.empty-icon { font-size: 80rpx; display: block; }
.empty-text { font-size: 28rpx; color: #999; }
.list { padding: 20rpx; }

.card { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 16rpx; }
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.order-no { font-size: 24rpx; color: #666; }
.status-tag { font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 16rpx; }
.status-tag.pending { background: #fff3e0; color: #e65100; }
.status-tag.approved { background: #e8f5e9; color: #2e7d32; }
.status-tag.rejected { background: #ffebee; color: #c62828; }
.status-tag.admin_approved { background: #e3f2fd; color: #1565c0; }
.status-tag.admin_rejected { background: #fce4ec; color: #880e4f; }

.card-body { border-top: 1rpx solid #f0f0f0; padding-top: 16rpx; }
.info-row { display: flex; margin-bottom: 10rpx; }
.info-label { font-size: 24rpx; color: #999; width: 140rpx; flex-shrink: 0; }
.info-value { font-size: 24rpx; color: #333; flex: 1; }
.info-value.time { color: #999; }

.card-actions { display: flex; gap: 20rpx; margin-top: 20rpx; padding-top: 16rpx; border-top: 1rpx solid #f0f0f0; }
.btn { flex: 1; height: 72rpx; line-height: 72rpx; font-size: 26rpx; border: none; border-radius: 12rpx; }
.btn-approve { background: #e8f5e9; color: #2e7d32; }
.btn-reject { background: #ffebee; color: #c62828; }

.merchant-reply, .admin-reply { margin-top: 12rpx; padding: 12rpx 16rpx; background: #f5f5f5; border-radius: 8rpx; }
.reply-label { font-size: 22rpx; color: #999; display: block; margin-bottom: 4rpx; }
.reply-content { font-size: 24rpx; color: #333; display: block; }
.reply-content.admin_approved { color: #1565c0; }
.reply-content.admin_rejected { color: #880e4f; }

/* 拒绝原因弹窗 */
.reject-modal-mask { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 999; display: flex; align-items: center; justify-content: center; }
.reject-modal { width: 600rpx; background: #fff; border-radius: 16rpx; padding: 32rpx; }
.reject-modal-title { font-size: 32rpx; font-weight: bold; color: #333; text-align: center; margin-bottom: 24rpx; }
.reject-input { width: 100%; height: 72rpx; font-size: 28rpx; padding: 16rpx; background: #f5f5f5; border-radius: 8rpx; box-sizing: border-box; margin-bottom: 24rpx; }
.reject-modal-btns { display: flex; gap: 20rpx; }
.reject-modal-btn { flex: 1; height: 72rpx; line-height: 72rpx; text-align: center; border-radius: 12rpx; font-size: 28rpx; }
.reject-modal-btn.cancel { background: #f0f0f0; color: #666; }
.reject-modal-btn.confirm { background: #ffebee; color: #c62828; }
