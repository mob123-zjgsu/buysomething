<view class="container">
  <view class="header">
    <text class="title">API 交互测试</text>
  </view>

  <!-- API 选择 -->
  <view class="section">
    <text class="section-title">选择 API</text>
    <view class="api-list">
      <view class="api-item {{selectedApi === 'register' ? 'active' : ''}}" bindtap="selectApi" data-api="register">
        <text>1. 用户注册</text>
      </view>
      <view class="api-item {{selectedApi === 'login' ? 'active' : ''}}" bindtap="selectApi" data-api="login">
        <text>2. 用户登录</text>
      </view>
      <view class="api-item {{selectedApi === 'products' ? 'active' : ''}}" bindtap="selectApi" data-api="products">
        <text>3. 获取商品列表</text>
      </view>
      <view class="api-item {{selectedApi === 'product-detail' ? 'active' : ''}}" bindtap="selectApi" data-api="product-detail">
        <text>4. 获取商品详情</text>
      </view>
      <view class="api-item {{selectedApi === 'delete-product' ? 'active' : ''}}" bindtap="selectApi" data-api="delete-product">
        <text>5. 删除商品</text>
      </view>
    </view>
  </view>

  <!-- 参数输入区 -->
  <view class="section" wx:if="{{selectedApi}}">
    <text class="section-title">参数配置</text>
    
    <!-- 注册参数 -->
    <view wx:if="{{selectedApi === 'register'}}">
      <view class="param-item">
        <text class="param-label">手机号 (phone)</text>
        <input class="param-input" placeholder="请输入手机号，如: 13800138001" value="{{registerParams.phone}}" bindinput="updateParam" data-key="phone" />
      </view>
      <view class="param-item">
        <text class="param-label">验证码 (code)</text>
        <input class="param-input" placeholder="请输入验证码，默认: 123456" value="{{registerParams.code}}" bindinput="updateParam" data-key="code" />
      </view>
      <view class="param-item">
        <text class="param-label">密码 (password)</text>
        <input class="param-input" password placeholder="请输入密码（6-20位）" value="{{registerParams.password}}" bindinput="updateParam" data-key="password" />
      </view>
    </view>

    <!-- 登录参数 -->
    <view wx:if="{{selectedApi === 'login'}}">
      <view class="param-item">
        <text class="param-label">手机号 (phone)</text>
        <input class="param-input" placeholder="请输入手机号" value="{{loginParams.phone}}" bindinput="updateParam" data-key="phone" />
      </view>
      <view class="param-item">
        <text class="param-label">密码 (password)</text>
        <input class="param-input" password placeholder="请输入密码" value="{{loginParams.password}}" bindinput="updateParam" data-key="password" />
      </view>
    </view>

    <!-- 商品列表参数 -->
    <view wx:if="{{selectedApi === 'products'}}">
      <view class="param-item">
        <text class="param-label">页码 (page)</text>
        <input class="param-input" type="number" placeholder="默认: 1" value="{{productsParams.page}}" bindinput="updateParam" data-key="page" />
      </view>
      <view class="param-item">
        <text class="param-label">每页数量 (pageSize)</text>
        <input class="param-input" type="number" placeholder="默认: 10" value="{{productsParams.pageSize}}" bindinput="updateParam" data-key="pageSize" />
      </view>
    </view>

    <!-- 商品详情参数 -->
    <view wx:if="{{selectedApi === 'product-detail'}}">
      <view class="param-item">
        <text class="param-label">商品ID (productId)</text>
        <input class="param-input" placeholder="请输入商品ID，如: d3a457a269dcef6d0423a88135e844c5" value="{{productDetailParams.productId}}" bindinput="updateParam" data-key="productId" />
      </view>
      <view class="tip">提示: 可先调用"获取商品列表"获取商品ID</view>
    </view>

    <!-- 删除商品参数 -->
    <view wx:if="{{selectedApi === 'delete-product'}}">
      <view class="param-item">
        <text class="param-label">商品ID (productId)</text>
        <input class="param-input" placeholder="请输入要删除的商品ID" value="{{deleteParams.productId}}" bindinput="updateParam" data-key="productId" />
      </view>
      <view class="tip warning">警告: 此操作不可逆!</view>
    </view>

    <!-- 发送请求按钮 -->
    <button class="btn-send" bindtap="sendRequest" disabled="{{loading}}">
      {{loading ? '请求中...' : '发送请求'}}
    </button>
  </view>

  <!-- 响应结果 -->
  <view class="section" wx:if="{{response}}">
    <text class="section-title">响应结果</text>
    <view class="response-box">
      <view class="response-status {{response.success || response.code === 0 ? 'success' : 'error'}}">
        {{response.success || response.code === 0 ? '成功' : '失败'}}
      </view>
      <text class="response-message">{{response.message || ''}}</text>
      <view class="response-data">
        <text class="data-label">完整响应:</text>
        <text class="data-content">{{responseStr}}</text>
      </view>
    </view>
  </view>

  <!-- 测试记录 -->
  <view class="section">
    <text class="section-title">测试记录 ({{testHistory.length}})</text>
    <view wx:for="{{testHistory}}" wx:key="index" class="history-item">
      <view class="history-header">
        <text class="history-api">{{item.api}}</text>
        <text class="history-time">{{item.time}}</text>
      </view>
      <text class="history-result {{item.success ? 'success' : 'error'}}">{{item.success ? '成功' : '失败'}}</text>
      <text class="history-message">{{item.message}}</text>
    </view>
  </view>
</view>
