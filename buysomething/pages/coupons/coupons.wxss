.coupons-container { background: #f5f5f5; min-height: 100vh; }
.tabs { display: flex; background: #fff; }
.tab { flex: 1; text-align: center; padding: 24rpx; font-size: 28rpx; color: #666; border-bottom: 4rpx solid transparent; }
.tab.active { color: #e74c3c; border-color: #e74c3c; font-weight: bold; }
.coupon-list { padding: 20rpx; }
.empty { text-align: center; padding: 150rpx 0; }
.empty-icon { font-size: 80rpx; display: block; }
.empty-text { font-size: 28rpx; color: #999; }
.coupon-card { display: flex; background: linear-gradient(135deg, #fff 60%, #fff0ef); border-radius: 12rpx; margin-bottom: 20rpx; overflow: hidden; position: relative; }
.coupon-card.used { opacity: 0.5; }
.coupon-left { width: 200rpx; padding: 24rpx; background: linear-gradient(135deg, #e74c3c, #c0392b); color: #fff; display: flex; flex-direction: column; justify-content: center; align-items: center; }
.coupon-value { font-size: 40rpx; font-weight: bold; }
.coupon-name { font-size: 22rpx; opacity: 0.9; margin-top: 8rpx; }
.coupon-right { flex: 1; padding: 24rpx; }
.coupon-condition { font-size: 24rpx; color: #666; display: block; }
.coupon-expire { font-size: 22rpx; color: #999; display: block; margin-top: 8rpx; }
.receive-btn { margin-top: 16rpx; background: #e74c3c; color: #fff; font-size: 24rpx; border-radius: 24rpx; padding: 10rpx 20rpx; border: none; width: auto; display: inline-block; }
.used-badge { position: absolute; right: 20rpx; top: 50%; transform: translateY(-50%); font-size: 24rpx; color: #999; }
