<!-- 管理员主页 -->
<view class="admin-home">
  <!-- 顶部信息 -->
  <view class="admin-header">
    <view class="admin-info">
      <text class="admin-name">{{adminName}}</text>
      <text class="admin-role">管理员</text>
    </view>
    <view class="logout-btn" bindtap="onLogout">退出</view>
  </view>

  <!-- 快速切换 -->
  <view class="switch-section">
    <text class="switch-title">🔄 快速切换角色</text>
    <view class="switch-buttons">
      <button class="btn-switch btn-user" bindtap="switchToUser">👤 用户端</button>
      <button class="btn-switch btn-merchant" bindtap="switchToMerchant">🏪 商家端</button>
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-section">
    <view class="stat-card">
      <text class="stat-value">{{stats.totalMerchants}}</text>
      <text class="stat-label">商家总数</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.totalProducts}}</text>
      <text class="stat-label">商品总数</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.totalUsers}}</text>
      <text class="stat-label">用户总数</text>
    </view>
  </view>

  <!-- 待审核 -->
  <view class="review-section">
    <!-- 商家审核 -->
    <view class="review-item" bindtap="onReviewMerchants">
      <view class="review-left">
        <text class="review-icon">🏪</text>
        <view class="review-info">
          <text class="review-title">商家审核</text>
          <text class="review-desc">审核新注册的商家账号</text>
        </view>
      </view>
      <view class="review-badge" wx:if="{{pendingMerchants > 0}}">{{pendingMerchants}}</view>
    </view>

    <!-- 商品审核 -->
    <view class="review-item" bindtap="onReviewProducts">
      <view class="review-left">
        <text class="review-icon">📦</text>
        <view class="review-info">
          <text class="review-title">商品审核</text>
          <text class="review-desc">审核商家上架的商品</text>
        </view>
      </view>
      <view class="review-badge" wx:if="{{pendingProducts > 0}}">{{pendingProducts}}</view>
    </view>
  </view>

  <!-- 列表项 -->
  <view class="list-section">
    <view class="list-item" bindtap="onAllMerchants">
      <text class="list-icon">👥</text>
      <text class="list-text">商家管理</text>
      <text class="list-arrow">›</text>
    </view>
    <view class="list-item" bindtap="onAllProducts">
      <text class="list-icon">📋</text>
      <text class="list-text">商品管理</text>
      <text class="list-arrow">›</text>
    </view>
    <view class="list-item" bindtap="onAllOrders">
      <text class="list-icon">⚖️</text>
      <text class="list-text">售后裁定</text>
      <text class="list-arrow">›</text>
    </view>
  </view>
</view>