<view class="product-detail-container">
  <!-- 商品图片轮播 -->
  <swiper class="product-swiper" indicator-dots circular>
    <swiper-item wx:for="{{product.images}}" wx:key="*this">
      <image class="product-image" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-index="{{index}}"></image>
    </swiper-item>
  </swiper>

  <!-- 商品信息 -->
  <view class="product-info">
    <view class="price-section">
      <text class="current-price">¥{{product.price}}</text>
      <text class="original-price" wx:if="{{product.originalPrice}}">¥{{product.originalPrice}}</text>
      <view class="discount-tag" wx:if="{{product.discount}}">{{product.discount}}</view>
    </view>

    <view class="product-title">{{product.name}}</view>
    <view class="product-subtitle">{{product.subtitle}}</view>

    <view class="product-stats">
      <text class="sales">月销 {{product.sales}}</text>
      <text class="rating">⭐{{product.rating}} · {{product.reviewCount}}条评价</text>
    </view>
  </view>

  <!-- 规格选择 -->
  <view class="spec-section" bindtap="openSpecSelector">
    <view class="spec-label">选择规格</view>
    <view class="spec-values">
      <text>{{selectedSpec || '请选择颜色、尺寸'}}</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 商品详情 -->
  <view class="detail-section">
    <view class="section-title">商品详情</view>
    <view class="detail-content">
      <image wx:for="{{product.detailImages}}" wx:key="*this" src="{{item}}" mode="widthFix" class="detail-image"></image>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="left-actions">
      <view class="action-item" bindtap="contactService">
        <text class="action-icon">💬</text>
        <text class="action-text">客服</text>
      </view>
      <view class="action-item" bindtap="toggleFavorite">
        <text class="action-icon">{{isFavorite ? '❤️' : '🤍'}}</text>
        <text class="action-text">收藏</text>
      </view>
    </view>
    <view class="right-actions">
      <button class="btn-add-cart" bindtap="addToCart">加入购物车</button>
      <button class="btn-buy-now" bindtap="buyNow">立即购买</button>
    </view>
  </view>

  <!-- 规格选择弹窗 -->
  <view class="spec-modal {{showSpecModal ? 'show' : ''}}">
    <view class="modal-mask" bindtap="closeSpecSelector"></view>
    <view class="modal-content">
      <view class="modal-header">
        <image class="spec-preview" src="{{product.images[0]}}" mode="aspectFill"></image>
        <view class="spec-info">
          <text class="spec-price">¥{{product.price}}</text>
          <text class="spec-selected">{{selectedSpec || '请选择规格'}}</text>
          <text class="spec-stock" wx:if="{{product.stock > 0}}">库存: {{product.stock}}件</text>
          <text class="spec-stock no-stock" wx:else>库存不足</text>
        </view>
      </view>

      <scroll-view scroll-y class="modal-body">
        <!-- 颜色选择 -->
        <view class="spec-group" wx:if="{{product.colors.length > 0}}">
          <view class="spec-group-title">颜色</view>
          <view class="spec-options">
            <view class="spec-option {{selectedColor === item ? 'active' : ''}}" wx:for="{{product.colors}}" wx:key="*this" bindtap="selectColor" data-color="{{item}}">
              <text>{{item}}</text>
            </view>
          </view>
        </view>

        <!-- 尺寸选择 -->
        <view class="spec-group" wx:if="{{product.sizes.length > 0}}">
          <view class="spec-group-title">尺寸</view>
          <view class="spec-options">
            <view class="spec-option {{selectedSize === item ? 'active' : ''}}" wx:for="{{product.sizes}}" wx:key="*this" bindtap="selectSize" data-size="{{item}}">
              <text>{{item}}</text>
            </view>
          </view>
        </view>

        <!-- 无规格时提示 -->
        <view class="no-spec-tip" wx:if="{{product.colors.length === 0 && product.sizes.length === 0}}">
          <text>该商品暂无规格选项</text>
        </view>

        <!-- 数量选择 -->
        <view class="quantity-section">
          <view class="spec-group-title">数量</view>
          <view class="quantity-selector">
            <button class="quantity-btn" bindtap="decreaseQuantity">-</button>
            <input class="quantity-input" type="number" value="{{quantity}}" disabled />
            <button class="quantity-btn" bindtap="increaseQuantity">+</button>
          </view>
        </view>
      </scroll-view>

      <view class="modal-footer">
        <button class="btn-confirm" bindtap="confirmSpec">确定</button>
      </view>
    </view>
  </view>
</view>
