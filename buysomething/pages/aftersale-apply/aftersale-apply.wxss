.container { min-height: 100vh; background: #f5f5f5; padding: 20rpx; padding-bottom: 120rpx; }

.form-card { background: #fff; border-radius: 16rpx; padding: 30rpx 24rpx; }

.form-title { font-size: 36rpx; font-weight: bold; color: #333; display: block; margin-bottom: 30rpx; }

.form-group { margin-bottom: 30rpx; }

.form-label { font-size: 28rpx; color: #333; font-weight: 500; display: block; margin-bottom: 12rpx; }

.form-picker { background: #f5f5f5; border-radius: 12rpx; padding: 20rpx 24rpx; }

.picker-value { font-size: 28rpx; color: #333; }

.form-textarea { width: 100%; min-height: 160rpx; background: #f5f5f5; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; color: #333; box-sizing: border-box; }

.char-count { font-size: 22rpx; color: #999; text-align: right; display: block; margin-top: 8rpx; }

.flow-hint { background: #f0f4ff; border-radius: 12rpx; padding: 24rpx; margin-top: 10rpx; }

.hint-title { font-size: 26rpx; color: #667eea; font-weight: 500; display: block; margin-bottom: 16rpx; }

.flow-steps { display: flex; align-items: center; justify-content: center; gap: 12rpx; }

.flow-step { display: flex; flex-direction: column; align-items: center; }

.step-dot { width: 40rpx; height: 40rpx; border-radius: 50%; background: #667eea; color: #fff; font-size: 22rpx; text-align: center; line-height: 40rpx; margin-bottom: 8rpx; }

.step-text { font-size: 22rpx; color: #555; text-align: center; }

.flow-arrow { font-size: 28rpx; color: #999; margin-bottom: 28rpx; }

.btn-submit { margin-top: 30rpx; height: 88rpx; line-height: 88rpx; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #fff; font-size: 32rpx; font-weight: bold; border-radius: 12rpx; border: none; }

.btn-submit[disabled] { background: #ccc; }
