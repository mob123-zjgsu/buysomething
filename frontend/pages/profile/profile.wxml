<view class="profile-container">
  <!-- 未登录状态 -->
  <view class="not-logged-in" wx:if="{{!isLogin}}">
    <view class="header-bg">
      <view class="header-content">
        <image class="avatar" src="/images/default-avatar.png" mode="aspectFill"></image>
        <view class="user-info">
          <text class="welcome-text">欢迎来到优选购物</text>
          <button class="btn-login" bindtap="goToLogin">登录/注册</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 已登录状态 -->
  <view class="logged-in" wx:else>
    <!-- 用户信息区 -->
    <view class="user-header">
      <view class="header-bg">
        <view class="header-content">
          <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" bindtap="editAvatar"></image>
          <view class="user-info">
            <text class="user-name">{{userInfo.nickName}}</text>
            <view class="member-tag">
              <text class="tag-icon">👑</text>
              <text class="tag-text">{{userInfo.memberLevel || '普通会员'}}</text>
            </view>
          </view>
          <text class="edit-icon" bindtap="editProfile">✏️</text>
        </view>

        <!-- 用户数据 -->
        <view class="user-stats">
          <view class="stat-item" bindtap="goToFavorites">
            <text class="stat-value">{{stats.favorites}}</text>
            <text class="stat-label">收藏</text>
          </view>
          <view class="stat-item" bindtap="goToFollows">
            <text class="stat-value">{{stats.follows}}</text>
            <text class="stat-label">关注</text>
          </view>
          <view class="stat-item" bindtap="goToFans">
            <text class="stat-value">{{stats.fans}}</text>
            <text class="stat-label">粉丝</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 订单状态区 -->
    <view class="order-section">
      <view class="section-header">
        <text class="section-title">我的订单</text>
        <view class="view-all" bindtap="goToOrders">
          <text class="view-all-text">查看全部</text>
          <text class="arrow">›</text>
        </view>
      </view>

      <view class="order-status">
        <view class="status-item" bindtap="goToOrders" data-status="pending">
          <view class="status-icon-wrapper">
            <text class="status-icon">💳</text>
            <view class="badge" wx:if="{{orderCounts.pending > 0}}">{{orderCounts.pending}}</view>
          </view>
          <text class="status-label">待付款</text>
        </view>
        <view class="status-item" bindtap="goToOrders" data-status="shipped">
          <view class="status-icon-wrapper">
            <text class="status-icon">📦</text>
            <view class="badge" wx:if="{{orderCounts.shipped > 0}}">{{orderCounts.shipped}}</view>
          </view>
          <text class="status-label">待发货</text>
        </view>
        <view class="status-item" bindtap="goToOrders" data-status="received">
          <view class="status-icon-wrapper">
            <text class="status-icon">🚚</text>
            <view class="badge" wx:if="{{orderCounts.received > 0}}">{{orderCounts.received}}</view>
          </view>
          <text class="status-label">待收货</text>
        </view>
        <view class="status-item" bindtap="goToOrders" data-status="commented">
          <view class="status-icon-wrapper">
            <text class="status-icon">⭐</text>
            <view class="badge" wx:if="{{orderCounts.commented > 0}}">{{orderCounts.commented}}</view>
          </view>
          <text class="status-label">待评价</text>
        </view>
        <view class="status-item" bindtap="goToOrders" data-status="refund">
          <view class="status-icon-wrapper">
            <text class="status-icon">↩️</text>
            <view class="badge" wx:if="{{orderCounts.refund > 0}}">{{orderCounts.refund}}</view>
          </view>
          <text class="status-label">退款/售后</text>
        </view>
      </view>
    </view>

    <!-- 功能列表区 -->
    <view class="function-list">
      <!-- API 交互测试 - 仅开发调试使用 -->
      <view class="function-item" style="background: #fff5f5;" bindtap="goToApiTest">
        <view class="item-left">
          <text class="item-icon">🧪</text>
          <text class="item-label" style="color: #ff6b6b;">API 交互测试</text>
        </view>
        <view class="item-right">
          <text class="arrow">›</text>
        </view>
      </view>

      <!-- 测试按钮 - 仅开发调试使用 -->
      <view class="function-item" style="background: #fff5f5;" bindtap="goToTest">
        <view class="item-left">
          <text class="item-icon">🔧</text>
          <text class="item-label" style="color: #ff6b6b;">自动测试</text>
        </view>
        <view class="item-right">
          <text class="arrow">›</text>
        </view>
      </view>

      <view class="function-item" bindtap="goToCoupons">
        <view class="item-left">
          <text class="item-icon">🎫</text>
          <text class="item-label">我的优惠券</text>
        </view>
        <view class="item-right">
          <view class="badge" wx:if="{{couponCount > 0}}">{{couponCount}}</view>
          <text class="arrow">›</text>
        </view>
      </view>

      <view class="function-item" bindtap="goToAddress">
        <view class="item-left">
          <text class="item-icon">📍</text>
          <text class="item-label">收货地址</text>
        </view>
        <view class="item-right">
          <text class="arrow">›</text>
        </view>
      </view>

      <view class="function-item" bindtap="goToContact">
        <view class="item-left">
          <text class="item-icon">💬</text>
          <text class="item-label">联系客服</text>
        </view>
        <view class="item-right">
          <text class="arrow">›</text>
        </view>
      </view>

      <view class="function-item" bindtap="goToSettings">
        <view class="item-left">
          <text class="item-icon">⚙️</text>
          <text class="item-label">设置</text>
        </view>
        <view class="item-right">
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 退出登录按钮 -->
    <view class="logout-section">
      <button class="btn-logout" bindtap="logout">退出登录</button>
    </view>
  </view>
</view>
