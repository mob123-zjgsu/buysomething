<view class="order-item {{mode}}" bindtap="onTap">
  <!-- 订单头部 -->
  <view class="order-header">
    <text class="order-no">订单号: {{order.orderNo}}</text>
    <text class="order-status" style="color: {{statusColorMap[order.status]}}">
      {{statusMap[order.status]}}
    </text>
  </view>

  <!-- 商品列表 -->
  <view class="goods-list">
    <view class="goods-item" wx:for="{{order.items}}" wx:key="index">
      <image class="goods-image" src="{{item.image || '/images/product1.jpg'}}" mode="aspectFill" />
      <view class="goods-info">
        <text class="goods-name">{{item.name}}</text>
        <text class="goods-spec" wx:if="{{item.color || item.size}}">
          {{item.color}} {{item.size}}
        </text>
        <view class="goods-bottom">
          <text class="goods-price">¥{{item.price}}</text>
          <text class="goods-quantity">x{{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 订单底部 -->
  <view class="order-footer">
    <view class="total-info">
      <text class="total-count">共{{order.totalQuantity || 1}}件</text>
      <text class="total-price">合计: ¥{{order.totalPrice}}</text>
    </view>
    
    <!-- 操作按钮 -->
    <view class="action-buttons" wx:if="{{mode === 'normal'}}">
      <button class="btn-action btn-cancel" wx:if="{{order.status === 'pending'}}" bindtap="onCancel">
        取消订单
      </button>
      <button class="btn-action btn-primary" wx:if="{{order.status === 'pending'}}" bindtap="onPay">
        去付款
      </button>
      <button class="btn-action btn-default" wx:if="{{order.status === 'shipped'}}" bindtap="onViewLogistics">
        查看物流
      </button>
      <button class="btn-action btn-primary" wx:if="{{order.status === 'shipped'}}" bindtap="onConfirmReceive">
        确认收货
      </button>
      <button class="btn-action btn-primary" wx:if="{{order.status === 'received'}}" bindtap="onBuyAgain">
        再次购买
      </button>
    </view>
  </view>
</view>
