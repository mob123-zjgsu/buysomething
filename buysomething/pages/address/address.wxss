.address-container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 140rpx;
}

/* 地址列表 */
.address-list {
  padding: 16rpx 24rpx;
}

.address-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.address-card.selectable:active {
  background-color: #F9F9F9;
}

.select-indicator {
  display: flex;
  align-items: center;
}

.select-text {
  font-size: 24rpx;
  color: #FF6B6B;
  margin-right: 8rpx;
}

.select-arrow {
  font-size: 28rpx;
  color: #CCCCCC;
}

.address-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.address-tags {
  display: flex;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  color: #666666;
  background-color: #F5F5F5;
  border-radius: 8rpx;
}

.tag.default {
  color: #FF6B6B;
  background-color: #FFF0F0;
}

.address-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  font-size: 24rpx;
  color: #666666;
}

.action-btn.delete {
  color: #FF4444;
}

.address-content {
  margin-bottom: 20rpx;
}

.address-name-phone {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.address-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-right: 24rpx;
}

.address-phone {
  font-size: 28rpx;
  color: #666666;
}

.address-detail {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.5;
}

.address-footer {
  display: flex;
  align-items: center;
}

.default-checkbox {
  margin-right: 12rpx;
}

.default-text {
  font-size: 28rpx;
  color: #666666;
}

/* 空状态 */
.empty-address {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 80rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
}

.add-icon {
  font-size: 32rpx;
}

.add-text {
  font-size: 28rpx;
  font-weight: 500;
}
