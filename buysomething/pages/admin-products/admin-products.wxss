.admin-products { min-height: 100vh; background: #F5F5F5; }
.tabs { display: flex; background: #FFF; padding: 20rpx 0; }
.tab { flex: 1; text-align: center; font-size: 28rpx; color: #666; padding: 16rpx 0; }
.tab.active { color: #667eea; border-bottom: 4rpx solid #667eea; }
.list { padding: 20rpx; }
.item { background: #FFF; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; display: flex; align-items: center; }
.img { width: 120rpx; height: 120rpx; border-radius: 12rpx; background: #EEE; }
.info { flex: 1; margin-left: 20rpx; }
.name { font-size: 28rpx; display: block; }
.price { font-size: 30rpx; color: #FF4757; font-weight: bold; margin-top: 8rpx; display: block; }
.actions { display: flex; gap: 16rpx; }
.btn { padding: 16rpx 24rpx; border-radius: 32rpx; font-size: 24rpx; }
.btn.approve { background: #E8F5E9; color: #4CAF50; }
.btn.reject, .btn.delete { background: #FFEBEE; color: #F44336; }
.empty { text-align: center; padding: 100rpx; color: #999; font-size: 28rpx; }
.detail-hint { font-size: 22rpx; color: #667eea; display: block; margin-top: 8rpx; }
/* 详情弹窗 */
.detail-modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 1000; }
.modal-mask { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); }
.modal-content { position: absolute; bottom: 0; left: 0; right: 0; max-height: 80vh; background: #fff; border-radius: 24rpx 24rpx 0 0; overflow-y: auto; }
.modal-header { display: flex; justify-content: space-between; align-items: center; padding: 30rpx; border-bottom: 1rpx solid #f0f0f0; }
.modal-title { font-size: 32rpx; font-weight: bold; color: #333; }
.close-btn { font-size: 36rpx; color: #999; padding: 10rpx; }
.modal-body { padding: 24rpx; }
.detail-img { width: 100%; height: 400rpx; border-radius: 12rpx; background: #eee; margin-bottom: 20rpx; }
.detail-row { display: flex; padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.dl { font-size: 26rpx; color: #999; width: 150rpx; flex-shrink: 0; }
.dv { font-size: 26rpx; color: #333; flex: 1; }
.detail-faq { padding: 20rpx 0; }
.faq-item { background: #f5f5f5; border-radius: 8rpx; padding: 16rpx; margin-bottom: 12rpx; }
.faq-q { font-size: 24rpx; color: #667eea; display: block; }
.faq-a { font-size: 24rpx; color: #666; display: block; margin-top: 8rpx; }