.order-item {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.order-no {
  font-size: 26rpx;
  color: #666666;
}

.order-status {
  font-size: 28rpx;
  font-weight: 500;
}

.goods-list {
  padding: 0 24rpx;
}

.goods-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.goods-name {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.4;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.goods-spec {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.goods-price {
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: 500;
}

.goods-quantity {
  font-size: 26rpx;
  color: #999999;
}

.order-footer {
  padding: 24rpx;
  border-top: 1rpx solid #F5F5F5;
}

.total-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.total-count {
  font-size: 26rpx;
  color: #666666;
}

.total-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF6B6B;
}

.action-buttons {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.btn-action {
  min-width: 160rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 26rpx;
  border-radius: 30rpx;
  padding: 0 24rpx;
  margin: 0;
}

.btn-action::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #FFFFFF;
}

.btn-default {
  background-color: #F5F5F5;
  color: #666666;
}

.btn-cancel {
  background-color: #FFFFFF;
  color: #999999;
  border: 1rpx solid #DDDDDD;
}
