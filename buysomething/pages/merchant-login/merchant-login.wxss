.merchant-login {
  min-height: 100vh;
  background-color: #FFFFFF;
  padding: 0 48rpx;
}

.back-btn {
  position: absolute;
  top: 40rpx;
  left: 32rpx;
  font-size: 56rpx;
  color: #333333;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  margin-bottom: 80rpx;
}

.logo-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.welcome-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.welcome-subtitle {
  font-size: 28rpx;
  color: #999999;
}

.login-form {
  margin-bottom: 40rpx;
}

.input-group {
  margin-bottom: 32rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  height: 96rpx;
  padding: 0 24rpx;
  background-color: #F5F5F5;
  border-radius: 48rpx;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.input-field {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.eye-icon {
  font-size: 36rpx;
  color: #999999;
}

.btn-login {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  margin-top: 20rpx;
}

.btn-login.disabled {
  background: #CCCCCC;
}

.register-section {
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  margin-top: 40rpx;
}

.register-text {
  color: #999999;
  margin-right: 8rpx;
}

.register-link {
  color: #667eea;
}

.switch-section {
  position: fixed;
  bottom: 80rpx;
  left: 0;
  right: 0;
  text-align: center;
}

.switch-text {
  font-size: 26rpx;
  color: #667eea;
  padding: 20rpx;
}

/* 验证码登录样式 */
.btn-code {
  font-size: 24rpx;
  color: #667eea;
  background: transparent;
  padding: 0 20rpx;
  border: none;
  white-space: nowrap;
}

.btn-code.countdown {
  color: #999999;
}

.switch-login {
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
}

/* 验证码显示区域 */
.code-display {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 20rpx;
  background-color: #f0f0f0;
  border-radius: 16rpx;
}

.code-label {
  font-size: 26rpx;
  color: #666666;
  margin-right: 10rpx;
}

.code-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #667eea;
  letter-spacing: 4rpx;
}