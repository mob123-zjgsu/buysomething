<view class="admin-merchants">
  <view class="tabs">
    <view class="tab {{tab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending">待审核</view>
    <view class="tab {{tab === 'approved' ? 'active' : ''}}" bindtap="switchTab" data-tab="approved">已通过</view>
  </view>
  <view class="list">
    <view class="item" wx:for="{{list}}" wx:key="_id">
      <view class="info">
        <text class="name">{{item.merchantName}}</text>
        <text class="desc">主营: {{item.mainProducts}}</text>
        <text class="phone">手机: {{item.phone}}</text>
      </view>
      <view class="actions" wx:if="{{tab === 'pending'}}">
        <view class="btn approve" bindtap="approve" data-id="{{item._id}}">通过</view>
        <view class="btn reject" bindtap="reject" data-id="{{item._id}}">拒绝</view>
      </view>
      <view class="btn delete" wx:if="{{tab === 'approved'}}" bindtap="deleteMerchant" data-id="{{item._id}}">删除</view>
    </view>
    <view class="empty" wx:if="{{list.length === 0}}">暂无数据</view>
  </view>
</view>