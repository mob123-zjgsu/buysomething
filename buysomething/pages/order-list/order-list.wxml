<view class="order-list-container">
  <!-- 订单状态筛选 -->
  <view class="order-tabs">
    <scroll-view scroll-x class="tabs-scroll">
      <view class="tab-item {{activeTab === 'all' ? 'active' : ''}}" bindtap="selectTab" data-tab="all">全部</view>
      <view class="tab-item {{activeTab === 'pending' ? 'active' : ''}}" bindtap="selectTab" data-tab="pending">待付款</view>
      <view class="tab-item {{activeTab === 'shipped' ? 'active' : ''}}" bindtap="selectTab" data-tab="shipped">待发货</view>
      <view class="tab-item {{activeTab === 'received' ? 'active' : ''}}" bindtap="selectTab" data-tab="received">待收货</view>
      <view class="tab-item {{activeTab === 'commented' ? 'active' : ''}}" bindtap="selectTab" data-tab="commented">待评价</view>
    </scroll-view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <view class="order-card" wx:for="{{orders}}" wx:key="id" bindtap="goToOrderDetail" data-id="{{item.id}}">
      <view class="order-header">
        <text class="order-shop">{{item.shopName}}</text>
        <text class="order-status {{item.status}}">{{item.statusText}}</text>
      </view>

      <view class="order-products">
        <view class="product-item" wx:for="{{item.products}}" wx:for-item="product" wx:key="uniqueId">
          <image class="product-image" src="{{product.image}}" mode="aspectFill"></image>
          <view class="product-info">
            <text class="product-name">{{product.name}}</text>
            <view class="product-spec">{{product.spec}}</view>
            <view class="product-price-row">
              <text class="product-price">¥{{product.price}}</text>
              <text class="product-quantity">x{{product.quantity}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="order-footer">
        <text class="order-total">共{{item.totalCount}}件 合计: <text class="total-price">¥{{item.totalPrice}}</text></text>
        <view class="order-actions">
          <button class="btn-action btn-secondary" bindtap="cancelOrder" data-id="{{item.id}}" wx:if="{{item.status === 'pending'}}">取消订单</button>
          <button class="btn-action btn-primary" bindtap="payOrder" data-id="{{item.id}}" wx:if="{{item.status === 'pending'}}">立即付款</button>
          <button class="btn-action btn-primary" bindtap="confirmOrder" data-id="{{item.id}}" wx:if="{{item.status === 'received'}}">确认收货</button>
          <button class="btn-action btn-primary" bindtap="commentOrder" data-id="{{item.id}}" wx:if="{{item.status === 'commented'}}">评价</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-orders" wx:if="{{orders.length === 0}}">
    <text class="empty-icon">📦</text>
    <text class="empty-text">暂无订单</text>
  </view>
</view>
