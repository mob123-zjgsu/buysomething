.address-edit-container {
  background: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
}

.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.input-group {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.input-group:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 12rpx;
  display: block;
}

.input {
  font-size: 28rpx;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.picker-display {
  font-size: 28rpx;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-display.placeholder {
  color: #999;
}

.picker-arrow {
  color: #999;
  font-size: 24rpx;
}

.tag-section, .default-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.tag-list {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.tag-item {
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  border: 2rpx solid #e0e0e0;
  font-size: 26rpx;
  color: #666;
}

.tag-item.active {
  border-color: #e74c3c;
  color: #e74c3c;
  background: #fff0ef;
}

.default-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.submit-section {
  padding: 40rpx 0;
}

.submit-btn {
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 24rpx;
}
