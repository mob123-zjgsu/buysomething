.splash-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background-color: #FFFFFF;
}

.logo-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B6B 0%, #4ECDC4 100%);
  margin-bottom: 20px;
}

.app-name {
  font-size: 24px;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8px;
}

.slogan {
  font-size: 14px;
  color: #999999;
}

.loading-bar {
  position: absolute;
  bottom: 100px;
  width: 200px;
  height: 3px;
  background-color: #EEEEEE;
  border-radius: 2px;
  overflow: hidden;
}

.loading-progress {
  height: 100%;
  background: linear-gradient(90deg, #FF6B6B 0%, #4ECDC4 100%);
  border-radius: 2px;
  transition: width 0.3s ease;
}
