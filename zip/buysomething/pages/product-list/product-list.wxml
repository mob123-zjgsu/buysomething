<view class="product-list-container">
  <!-- 顶部导航栏 -->
  <view class="navbar">
    <view class="back-btn" bindtap="goBack">
      <text>‹</text>
    </view>
    <view class="navbar-title">
      <text>{{categoryName || '商品列表'}}</text>
    </view>
    <view class="navbar-right">
      <text class="search-icon" bindtap="goToSearch">🔍</text>
      <text class="menu-icon" bindtap="showMenu">⋯</text>
    </view>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-bar">
    <scroll-view scroll-x class="filter-scroll">
      <view class="filter-item {{activeFilter === 'all' ? 'active' : ''}}" bindtap="selectFilter" data-type="all">
        <text>综合</text>
      </view>
      <view class="filter-item {{activeFilter === 'sales' ? 'active' : ''}}" bindtap="selectFilter" data-type="sales">
        <text>销量</text>
      </view>
      <view class="filter-item {{activeFilter === 'price' ? 'active' : ''}}" bindtap="selectFilter" data-type="price">
        <text>价格</text>
        <text class="sort-icon {{priceSort === 'asc' ? 'asc' : ''}}">⇅</text>
      </view>
      <view class="filter-item {{activeFilter === 'filter' ? 'active' : ''}}" bindtap="openFilterDrawer">
        <text>筛选</text>
        <text>⚙️</text>
      </view>
    </scroll-view>
  </view>

  <!-- 商品网格 -->
  <view class="product-grid">
    <view class="product-card" wx:for="{{products}}" wx:key="productId" bindtap="goToProductDetail" data-id="{{item.productId}}">
      <image class="product-image" src="{{item.image}}" mode="aspectFill"></image>
      <view class="product-info">
        <text class="product-name">{{item.name}}</text>
        <view class="product-tags" wx:if="{{item.tags}}">
          <text class="tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
        </view>
        <view class="product-price-row">
          <text class="product-price">¥{{item.price}}</text>
          <text class="product-original-price" wx:if="{{item.originalPrice}}">¥{{item.originalPrice}}</text>
        </view>
        <view class="product-sales">
          <text>月销 {{item.sales}}</text>
          <text class="rating">⭐{{item.rating}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore}}">
    <text>加载中...</text>
  </view>
  <view class="load-more" wx:else>
    <text>没有更多了</text>
  </view>

  <!-- 筛选抽屉 -->
  <view class="filter-drawer {{showFilter ? 'show' : ''}}">
    <view class="drawer-mask" bindtap="closeFilterDrawer"></view>
    <view class="drawer-content">
      <view class="drawer-header">
        <text class="drawer-title">筛选</text>
        <text class="reset-btn" bindtap="resetFilter">重置</text>
      </view>

      <scroll-view scroll-y class="drawer-body">
        <!-- 价格区间 -->
        <view class="filter-section">
          <view class="section-title">价格区间</view>
          <view class="price-range">
            <input class="price-input" type="digit" placeholder="最低价" bindinput="onMinPriceChange" value="{{minPrice}}"/>
            <text class="price-separator">-</text>
            <input class="price-input" type="digit" placeholder="最高价" bindinput="onMaxPriceChange" value="{{maxPrice}}"/>
          </view>
        </view>

        <!-- 品牌筛选 -->
        <view class="filter-section">
          <view class="section-title">品牌</view>
          <view class="brand-list">
            <view class="brand-item {{selectedBrands.includes(item) ? 'selected' : ''}}" wx:for="{{brands}}" wx:key="*this" bindtap="toggleBrand" data-brand="{{item}}">
              <text>{{item}}</text>
              <text class="check-icon" wx:if="{{selectedBrands.includes(item)}}">✓</text>
            </view>
          </view>
        </view>

        <!-- 评分筛选 -->
        <view class="filter-section">
          <view class="section-title">评分</view>
          <view class="rating-options">
            <view class="rating-item {{selectedRating === 4 ? 'selected' : ''}}" bindtap="selectRating" data-rating="4">
              <text>4星以上</text>
            </view>
            <view class="rating-item {{selectedRating === 3 ? 'selected' : ''}}" bindtap="selectRating" data-rating="3">
              <text>3星以上</text>
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="drawer-footer">
        <button class="btn-reset" bindtap="resetFilter">重置</button>
        <button class="btn-confirm" bindtap="applyFilter">确定</button>
      </view>
    </view>
  </view>
</view>
