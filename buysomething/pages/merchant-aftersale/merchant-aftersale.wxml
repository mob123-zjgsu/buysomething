<view class="container">
  <view class="tabs">
    <view class="tab {{activeTab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending">待审核</view>
    <view class="tab {{activeTab === 'approved' ? 'active' : ''}}" bindtap="switchTab" data-tab="approved">已同意</view>
    <view class="tab {{activeTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">全部</view>
  </view>

  <view class="empty" wx:if="{{list.length === 0}}">
    <text class="empty-icon">📋</text>
    <text class="empty-text">暂无售后申请</text>
  </view>

  <view class="list">
    <view class="card" wx:for="{{list}}" wx:key="id" wx:if="{{activeTab === 'all' || (activeTab === 'pending' && item.status === 'pending') || (activeTab === 'approved' && item.status === 'approved')}}">
      <view class="card-header">
        <text class="order-no">{{item.orderNo}}</text>
        <text class="status-tag {{item.status}}">{{item.statusText}}</text>
      </view>

      <view class="card-body">
        <view class="info-row">
          <text class="info-label">售后类型</text>
          <text class="info-value">{{item.type}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">申请理由</text>
          <text class="info-value">{{item.reason}}</text>
        </view>
        <view class="info-row" wx:if="{{item.detail}}">
          <text class="info-label">详细描述</text>
          <text class="info-value">{{item.detail}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">申请时间</text>
          <text class="info-value time">{{item.createTimeStr}}</text>
        </view>
      </view>

      <!-- 商家审核操作 -->
      <view class="card-actions" wx:if="{{item.status === 'pending'}}">
        <button class="btn btn-approve" bindtap="approveAftersale" data-id="{{item.id}}">同意</button>
        <button class="btn btn-reject" bindtap="rejectAftersale" data-id="{{item.id}}">反对</button>
      </view>

      <!-- 商家已拒绝，显示商家意见 -->
      <view class="merchant-reply" wx:if="{{item.status === 'rejected' || item.status === 'admin_approved' || item.status === 'admin_rejected'}}">
        <text class="reply-label">商家意见：</text>
        <text class="reply-content">{{item.merchantReply || '无'}}</text>
      </view>

      <!-- 管理员裁定结果 -->
      <view class="admin-reply" wx:if="{{item.status === 'admin_approved' || item.status === 'admin_rejected'}}">
        <text class="reply-label">管理员裁定：</text>
        <text class="reply-content {{item.status}}">{{item.adminReply || (item.status === 'admin_approved' ? '同意售后' : '驳回售后')}}</text>
      </view>
    </view>
  </view>

  <!-- 拒绝原因弹窗 -->
  <view class="reject-modal-mask" wx:if="{{showRejectModal}}" bindtap="closeRejectModal">
    <view class="reject-modal" catchtap="">
      <view class="reject-modal-title">拒绝售后</view>
      <input class="reject-input" placeholder="请输入拒绝原因和商家证据" value="{{rejectReason}}" bindinput="onRejectReasonInput" maxlength="200" />
      <view class="reject-modal-btns">
        <view class="reject-modal-btn cancel" bindtap="closeRejectModal">取消</view>
        <view class="reject-modal-btn confirm" bindtap="confirmReject">提交反对意见</view>
      </view>
    </view>
  </view>
</view>
