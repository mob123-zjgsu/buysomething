.review-container { background: #f5f5f5; min-height: 100vh; padding: 20rpx; }
.review-title { font-size: 32rpx; font-weight: bold; color: #333; padding: 20rpx; text-align: center; }
.rating-section, .content-section, .image-section { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; }
.label { font-size: 28rpx; color: #333; font-weight: bold; display: block; margin-bottom: 16rpx; }
.stars { display: flex; gap: 16rpx; }
.star { font-size: 48rpx; }
.star.active { color: #FFB300; }
.review-textarea { width: 100%; min-height: 200rpx; font-size: 28rpx; padding: 16rpx; background: #f5f5f5; border-radius: 8rpx; }
.char-count { text-align: right; font-size: 22rpx; color: #999; }
.image-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.image-item { position: relative; width: 160rpx; height: 160rpx; }
.review-img { width: 100%; height: 100%; border-radius: 8rpx; }
.del-img { position: absolute; top: -10rpx; right: -10rpx; width: 40rpx; height: 40rpx; background: #e74c3c; color: #fff; border-radius: 50%; text-align: center; line-height: 40rpx; font-size: 24rpx; }
.add-image { width: 160rpx; height: 160rpx; background: #f0f0f0; border-radius: 8rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.add-icon { font-size: 48rpx; color: #999; display: block; }
.add-text { font-size: 22rpx; color: #999; }
.submit-section { padding: 40rpx 0; }
.submit-btn { background: linear-gradient(135deg, #e74c3c, #c0392b); color: #fff; border: none; border-radius: 12rpx; font-size: 32rpx; padding: 24rpx; }
