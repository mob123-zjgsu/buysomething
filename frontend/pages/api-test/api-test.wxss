.container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

/* API 列表 */
.api-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.api-item {
  padding: 24rpx;
  background-color: #F8F8F8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  font-size: 28rpx;
  color: #666666;
}

.api-item.active {
  background-color: #FFF0F0;
  border-color: #FF6B6B;
  color: #FF6B6B;
  font-weight: 500;
}

/* 参数输入 */
.param-item {
  margin-bottom: 24rpx;
}

.param-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
  display: block;
}

.param-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background-color: #F8F8F8;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.tip {
  font-size: 24rpx;
  color: #999999;
  margin-top: 12rpx;
  padding: 16rpx;
  background-color: #F8F8F8;
  border-radius: 8rpx;
}

.tip.warning {
  color: #FF6B6B;
  background-color: #FFF0F0;
}

/* 发送按钮 */
.btn-send {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  margin-top: 24rpx;
}

.btn-send[disabled] {
  background: #CCCCCC;
}

/* 响应结果 */
.response-box {
  background-color: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx;
}

.response-status {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.response-status.success {
  background-color: #E8F8E8;
  color: #52C41A;
}

.response-status.error {
  background-color: #FFF0F0;
  color: #FF6B6B;
}

.response-message {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}

.response-data {
  border-top: 1rpx solid #EEEEEE;
  padding-top: 16rpx;
}

.data-label {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-bottom: 8rpx;
}

.data-content {
  font-size: 22rpx;
  color: #666666;
  word-break: break-all;
  white-space: pre-wrap;
  font-family: monospace;
  background-color: #FFFFFF;
  padding: 16rpx;
  border-radius: 8rpx;
  display: block;
}

/* 测试历史 */
.history-item {
  padding: 20rpx;
  background-color: #F8F8F8;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.history-api {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.history-time {
  font-size: 24rpx;
  color: #999999;
}

.history-result {
  font-size: 24rpx;
  margin-bottom: 4rpx;
  display: block;
}

.history-result.success {
  color: #52C41A;
}

.history-result.error {
  color: #FF6B6B;
}

.history-message {
  font-size: 24rpx;
  color: #666666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}
